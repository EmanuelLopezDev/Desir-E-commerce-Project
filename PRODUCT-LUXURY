  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 22px;
  padding: 16px 20px;
  border-radius: 18px;
  background: linear-gradient(145deg, rgba(37,211,102,0.07), rgba(19,12,12,0.4));
  border: 1px solid rgba(76,175,125,0.25);
  text-decoration: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.luxury-whatsapp-trust::before {
  content: '';
  position: absolute;
  top: 0;
  left: 8%;
  right: 8%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(76,175,125,0.4), transparent);
}

.luxury-whatsapp-trust:hover {
  border-color: rgba(76,175,125,0.5);
  background: linear-gradient(145deg, rgba(37,211,102,0.12), rgba(19,12,12,0.5));
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.3), 0 0 18px rgba(76,175,125,0.1);
}

.lwt-icon {
  width: 38px;
  height: 38px;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(145deg, #2bd966, #1faa50);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3), inset 0 -2px 4px rgba(0,0,0,0.15);
}

.lwt-icon svg {
  width: 19px;
  height: 19px;
  color: #ffffff;
}

.lwt-text {
  flex: 1;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.45;
  color: rgba(240,232,228,0.85);
  letter-spacing: 0.2px;
}

.lwt-arrow {
  font-family: 'Jost', sans-serif;
  font-size: 20px;
  color: rgba(76,175,125,0.6);
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.luxury-whatsapp-trust:hover .lwt-arrow {
  transform: translateX(4px);
  color: rgba(76,175,125,0.9);
}

.luxury-description {
  margin-top: 40px;
  padding: 28px;
  border: 1px solid rgba(200,145,58,0.2);
  border-radius: 18px;
  background: linear-gradient(145deg, #130c0c, #0e0808);
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(240,232,228,0.65);
  letter-spacing: 0.2px;
}

.luxury-cart-message {
  margin: 15px 0;
  padding: 12px 18px;
  border-radius: 12px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  display: none;
  transition: all 0.3s ease;
}

.luxury-cart-message.success {
