  }

  .luxury-whatsapp-trust {
    margin-top: 16px;
    padding: 13px 16px;
    border-radius: 14px;
  }

  .lwt-icon { width: 32px; height: 32px; }
  .lwt-icon svg { width: 16px; height: 16px; }
  .lwt-text { font-size: 12px; }

  .luxury-description { padding: 16px; font-size: 13px; margin-top: 18px; }
}

</style>

<script>
function changeImage(element) {
  var main = document.getElementById("mainProductImage");
  if (main && element) {
    main.src = element.getAttribute("data-large") || element.src;
  }
}
window.changeImage = changeImage;
</script>

<script>
(function () {

  document.addEventListener("DOMContentLoaded", function () {

    const form          = document.querySelector(".luxury-info form");
    if (!form) return;

    const messageBox    = document.querySelector(".luxury-cart-message");
    const variantInput  = form.querySelector('input[name="id"]');
    const quantityInput = document.getElementById("quantityInput");
    const addToCartBtn  = document.getElementById("addToCartBtn");
    const buyNowWrapper = document.getElementById("buyNowWrapper");
    const noStockMsg    = document.getElementById("noStockMsg");
    const stockDot      = document.getElementById("stockDot");
    const stockText     = document.getElementById("stockText");

    const variants = [
      {% for variant in product.variants %}
        {
          "id": {{ variant.id }},
          "available": {{ variant.available }},
          "options": {{ variant.options | json }},
          "inventory_quantity": {{ variant.inventory_quantity }},
          "inventory_management": {{ variant.inventory_management | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    /* ---- Corregir cantidad solo al salir del campo ---- */
    if (quantityInput) {
      quantityInput.addEventListener("blur", function () {
        let val   = parseInt(this.value);
        const max = parseInt(this.max);
        if (isNaN(val) || val < 1) val = 1;
        if (this.max !== "" && !isNaN(max) && val > max) val = max;
        this.value = val;
      });
    }

    /* ---- Badge de stock + ajuste inmediato de cantidad ---- */
    function updateStockBadge(variant) {
      if (!variant) {
        stockDot.className = "stock-dot out";
        stockText.textContent = "Sin variante";
        return;
      }

      const qty      = variant.inventory_quantity;
      const policy   = variant.inventory_management;
      const available= variant.available;

      if (policy === "shopify" && qty > 0) {
        quantityInput.setAttribute("max", qty);
        const currentQty = parseInt(quantityInput.value);
        if (!isNaN(currentQty) && currentQty > qty) {
          quantityInput.value = qty;
        }
      } else {
        quantityInput.removeAttribute("max");
      }

      if (!available || (policy === "shopify" && qty <= 0)) {
        stockDot.className = "stock-dot out";
        stockText.textContent = "Agotado";
        setButtonsDisabled(true);
      } else if (policy === "shopify" && qty <= 5) {
        stockDot.className = "stock-dot low";
        stockText.textContent = "Últimas " + qty + " unidades";
        setButtonsDisabled(false);
      } else if (policy === "shopify") {
        stockDot.className = "stock-dot";
        stockText.textContent = qty + " disponibles";
        setButtonsDisabled(false);
      } else {
        stockDot.className = "stock-dot";
        stockText.textContent = "Disponible";
        setButtonsDisabled(false);
      }
    }

    /* ---- Habilitar / deshabilitar botones ---- */
    function setButtonsDisabled(disabled) {
      if (disabled) {
        addToCartBtn.disabled = true;
        addToCartBtn.classList.add("disabled");
        noStockMsg.style.display = "block";
        if (buyNowWrapper) buyNowWrapper.style.display = "none";
      } else {
        addToCartBtn.disabled = false;
        addToCartBtn.classList.remove("disabled");
        noStockMsg.style.display = "none";
        if (buyNowWrapper) buyNowWrapper.style.display = "block";
      }
    }

    /* ---- Variante seleccionada ---- */
    function getSelectedVariant() {
      const optionBlocks = form.querySelectorAll(".luxury-option");
      const selected = [];
      optionBlocks.forEach(block => {
        const checked = block.querySelector("input:checked");
        if (checked) selected.push(checked.value);
      });
      return variants.find(v =>
        v.options.every((opt, i) => opt === selected[i])
      ) || null;
    }

    function updateVariant() {
      const matched = getSelectedVariant();
      if (matched && variantInput) variantInput.value = matched.id;
      updateStockBadge(matched);
    }

    form.querySelectorAll("input[type='radio']").forEach(radio => {
      radio.addEventListener("change", updateVariant);
    });

    updateVariant();

    /* ---- Mensaje carrito ---- */
    function showMessage(text, type = "success") {
      if (!messageBox) return;
      messageBox.style.display = "block";
      messageBox.className = "luxury-cart-message " + type;
      messageBox.innerHTML = text;
      if (type !== "error") {
        setTimeout(() => { messageBox.style.display = "none"; }, 5000);
      }
    }

    /* ---- Disparar evento nativo de Horizon ---- */
    function notifyHorizon(cart, variantId) {

      /* Exactamente la misma estructura que usa CartAddEvent en events.js de Horizon */
      const event = new CustomEvent('cart:update', {
        bubbles: true,
        detail: {
          resource: cart,
          sourceId: 'luxury-product-form',
          data: {
            didError: false,
            source: 'product-form',
            itemCount: cart.item_count,
            variantId: String(variantId)
          }
        }
      });

      /* Horizon escucha este evento en document, igual que hace su CartDrawerComponent */
      document.dispatchEvent(event);

      /* También actualizar el contador manualmente por si acaso */
      const selectors = [
        '[data-testid="cart-bubble"]',
        '.cart-bubble__text-count',
        '.cart-count',
        '.cart-count-bubble',
        '.cart-item-count',
        '[data-cart-count]',
        '.header__cart-count',
        '[id*="cart-count"]',
        '[class*="cart-count"]',
        '[class*="cart-bubble"]'
      ];
      selectors.forEach(sel => {
        document.querySelectorAll(sel).forEach(el => {
          el.textContent = cart.item_count;
          if (cart.item_count > 0) {
            el.style.display = '';
            el.removeAttribute('hidden');
            el.classList.remove('hidden', 'is-hidden', 'hide');
          }
        });
      });

      /* Texto accesible */
      document.querySelectorAll('#cart-bubble-text .visually-hidden, [data-cart-count-text]').forEach(el => {
        el.textContent = 'Total de artículos en el carrito: ' + cart.item_count;
      });
    }

    /* ---- Submit ---- */
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      if (addToCartBtn.disabled) return;

      updateVariant();

      const id  = variantInput.value;
      let qty   = parseInt(quantityInput.value);
      if (isNaN(qty) || qty < 1) qty = 1;

      if (!id) {
        showMessage("Selecciona una variante válida.", "error");
        return;
      }

      const button = form.querySelector("button[type='submit']");
      if (button) { button.disabled = true; button.textContent = "Agregando..."; }

      fetch("/cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({ id, quantity: qty })
      })
      .then(res => { if (!res.ok) throw new Error("Error"); return fetch("/cart.js"); })
      .then(res => res.json())
      .then(cart => {
        notifyHorizon(cart, id);
        showMessage('✔ Producto agregado — <a href="/cart" style="color:#4caf7d;font-weight:600;text-decoration:underline;">Ver carrito</a>', "success");
      })
      .catch(() => showMessage("Error al agregar el producto. Intenta de nuevo.", "error"))
      .finally(() => {
        if (button) { button.disabled = false; button.textContent = "Agregar al carrito"; }
      });
    });

  });

})();
</script>

