  }

  .luxury-title { font-size: 26px; margin-bottom: 8px; }
  .luxury-price { font-size: 18px; }
  .luxury-compare-price { font-size: 13px; }
  .luxury-divider { margin: 14px 0; }
  .luxury-option { margin-bottom: 14px; }
  .luxury-option-title { font-size: 10px; }

  .variant-button span { padding: 7px 14px; font-size: 12px; }

  .luxury-quantity { margin: 8px 0; }
  .luxury-quantity input { width: 65px; padding: 7px 10px; }

  .luxury-buttons { flex-direction: column; gap: 14px; }
  .luxury-buttons form { width: 100% !important; margin: 0 !important; }

  .luxury-buttons form button,
  .luxury-btn-primary {
    width: 100% !important;
    height: 50px !important;
    min-height: 50px !important;
    padding: 0 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
